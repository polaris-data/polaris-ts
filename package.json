{
  "name": "polaris-data",
  "version": "0.4.0",
  "description": "TypeScript SDK for the Polaris market data API",
  "license": "MIT",
  "author": "Polaris <hello@polaris.supply>",
  "homepage": "https://polaris.supply",
  "repository": {
    "type": "git",
    "url": "https://github.com/polaris-data/polaris-ts"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "polaris",
    "market-data",
    "crypto",
    "defi",
    "trading",
    "api",
    "sdk",
    "ohlcv",
    "trades",
    "events"
  ],
  "dependencies": {
    "fzstd": "^0.1.1"
  }
}
